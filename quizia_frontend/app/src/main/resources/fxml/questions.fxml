<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.HBox?>
<AnchorPane fx:id="root" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.quizia.frontend.controller.QuestionsController" style="-fx-background-color: white;">
    <children>
        <VBox layoutX="20" layoutY="20" spacing="10.0" AnchorPane.leftAnchor="20" AnchorPane.topAnchor="20">
            <Label fx:id="roomLabel" text="Room: -" />
            <Label fx:id="topicLabel" text="Topic: -" />
            <VBox spacing="8.0">
                <Label fx:id="questionText" text="Question will appear here" wrapText="true" prefWidth="600" />
                <VBox spacing="6.0">
                    <RadioButton fx:id="optA" toggleGroup="$answers" text="Option A" />
                    <RadioButton fx:id="optB" toggleGroup="$answers" text="Option B" />
                    <RadioButton fx:id="optC" toggleGroup="$answers" text="Option C" />
                    <RadioButton fx:id="optD" toggleGroup="$answers" text="Option D" />
                </VBox>
                <HBox spacing="8.0">
                    <Button fx:id="prevBtn" text="Previous" onAction="#onPrevious" />
                    <Button fx:id="nextBtn" text="Next" onAction="#onNext" />
                    <Button fx:id="submitBtn" text="Submit" onAction="#onSubmit" />
                </HBox>
            </VBox>
            <Button text="Back to Topics" onAction="#onBackToTopics" />
        </VBox>
    </children>
</AnchorPane>
